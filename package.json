{
  "name": "json_explorer",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Reusable Data Explorer UI components for MongoDB real-time dashboards.",
  "main": "dist/Json_explorer.cjs",
  "module": "dist/Json_explorer.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/Json_explorer.js",
      "require": "./dist/Json_explorer.cjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "gh-pages -d dist"
  },
  "homepage": "https://jsb0315.github.io/Json_explorer/",
  "peerDependencies": {
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "gh-pages": "^6.3.0",
    "lucide-react": "^0.469.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
